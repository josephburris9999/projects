<plugin>

  <extension point="org.eclipse.ui.commands">
   <category name="%category.name"
     id="com.all9ssolutions.ender.commands.category"/>
   <command name="%command.name"
     categoryId="com.all9ssolutions.ender.commands.category"
     id="com.all9ssolutions.ender.commands.enderCommand"/>
  </extension>
  <extension point="org.eclipse.ui.commandImages">
    <image
      commandId="com.all9ssolutions.ender.commands.enderCommand"
      icon="icons/end.png"/>
  </extension>
  <extension point="org.eclipse.ui.handlers">
    <handler commandId="com.all9ssolutions.ender.commands.enderCommand"
      class="com.all9ssolutions.ender.handlers.Handler"/>
  </extension>
  <extension point="org.eclipse.ui.bindings">
    <key commandId="com.all9ssolutions.ender.commands.enderCommand"
      contextId="org.eclipse.jdt.ui.javaEditorScope"
      sequence="M1+M2+E"
      schemeId="org.eclipse.ui.defaultAcceleratorConfiguration"/>
  </extension>
  <extension point="org.eclipse.ui.menus">
    <menuContribution locationURI="toolbar:org.eclipse.ui.main.toolbar?after=additions">
      <toolbar id="com.all9ssolutions.ender.toolbars.EnderToolbar">
        <command commandId="com.all9ssolutions.ender.commands.enderCommand"
          icon="icons/end.png"
          tooltip="%command.tooltip"
          id="com.all9ssolutions.ender.toolbars.enderCommand">
          <visibleWhen checkEnabled="false">
            <reference definitionId="when.java.is.active" />
          </visibleWhen>
        </command>
      </toolbar>
    </menuContribution>
    <menuContribution locationURI="popup:org.eclipse.ui.popup.any"
      allPopups="false">
      <command label="%command.label"
        style="push"
        commandId="com.all9ssolutions.ender.commands.enderCommand"
        icon="icons/end.png">
        <visibleWhen checkEnabled="false">
          <reference definitionId="when.java.is.active" />
        </visibleWhen>
      </command>
    </menuContribution>
  </extension>
  <extension point="org.eclipse.help.toc">
    <toc file="toc.xml"
      primary="true"/>
  </extension>
  <extension point="org.eclipse.help.contexts">
    <contexts file="ender_context.xml" plugin ="com.all9ssolutions.ender"/>
  </extension>
  <extension point="org.eclipse.core.expressions.definitions">
    <definition id="when.java.is.active">
      <with variable="activeContexts">
        <iterate operator="or">
          <equals value="org.eclipse.jdt.ui.javaEditorScope"/>
        </iterate>
      </with>
    </definition>
  </extension>
  <extension point="org.eclipse.ui.preferencePages">
    <page class="com.all9ssolutions.ender.preferences.PreferencePage"
      category="org.eclipse.ui.preferencePages.Workbench"
      id="com.all9ssolutions.ender.preferences.PreferencePage"
      name="%preferences.page.title">
      <keywordReference id="com.all9ssolutions.preferences.keywords.ender"/>
    </page>
  </extension>
  <extension point="org.eclipse.core.runtime.preferences">
    <initializer class="com.all9ssolutions.ender.preferences.PreferenceInitializer"/>
  </extension>
  <extension point="org.eclipse.ui.keywords">
    <keyword label="%preferences.page.keywords"
      id="com.all9ssolutions.preferences.keywords.ender"/>
  </extension>
  <extension point="org.eclipse.equinox.preferences.preferences">
  </extension>
</plugin>
