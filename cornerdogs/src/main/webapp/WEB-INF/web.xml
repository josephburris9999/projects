<?xml version="1.0" encoding="UTF-8"?>
<web-app id="WebApp_ID" version="6.1" xmlns="https://jakarta.ee/xml/ns/jakartaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_1.xsd">
	<display-name>cornerdogs</display-name>
	<description>
    Sample site demonstrating a wizard format using Jakarta EE APIs.
  </description>
  <servlet>
    <servlet-name>Startup</servlet-name>
    <servlet-class>com.all9ssolutions.cornerdogs.servlets.StartupServlet</servlet-class>
    <init-param>
      <param-name>LOG_DIRECTORY</param-name>
      <param-value>./logs</param-value>
    </init-param>
    <init-param>
      <param-name>HOT_DOG_PRICE</param-name>
      <param-value>.99</param-value>
    </init-param>
    <init-param>
      <param-name>TAX_RATE</param-name>
      <param-value>.25</param-value>
    </init-param>
    <load-on-startup>0</load-on-startup>
  </servlet>
  <welcome-file-list>
    <welcome-file>index.jsp</welcome-file>
  </welcome-file-list>
  <session-config>
    <session-timeout>60</session-timeout>
  </session-config>
  <error-page>
    <exception-type>java.lang.Throwable</exception-type>
    <location>/pages/error.jsp</location>
  </error-page>
  <error-page>
    <error-code>400</error-code>
    <location>/pages/error.jsp</location>
  </error-page>
  <error-page>
    <error-code>401</error-code>
    <location>/pages/error.jsp</location>
  </error-page>
  <error-page>
    <error-code>402</error-code>
    <location>/pages/error.jsp</location>
  </error-page>
  <error-page>
    <error-code>403</error-code>
    <location>/pages/error.jsp</location>
  </error-page>
  <error-page>
    <error-code>404</error-code>
    <location>/pages/error.jsp</location>
  </error-page>
  <error-page>
    <error-code>405</error-code>
    <location>/pages/error.jsp</location>
  </error-page>
  <error-page>
    <error-code>500</error-code>
    <location>/pages/error.jsp</location>
  </error-page>
</web-app>